# =============================================================================
# Generative Agent Simulation Engine — Environment Configuration
# =============================================================================
# Copy this file to `.env` and fill in your actual values.
# NEVER commit the `.env` file to version control.
# =============================================================================

# --- LLM Provider API Keys ---
OPENAI_API_KEY=sk-your-openai-api-key-here
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key-here
GOOGLE_AI_API_KEY=your-google-ai-api-key-here

# --- Vector Database Configuration ---
VECTOR_DB_ENDPOINT=http://localhost:6333
VECTOR_DB_API_KEY=your-vector-db-api-key-here
VECTOR_DB_COLLECTION_NAME=agent_memory_embeddings

# --- Simulation Engine Settings ---
SIMULATION_LOG_LEVEL=INFO
TARGET_ACCURACY_SCORE=0.85
MAX_INTERVIEW_TURNS=50

# --- Data Storage ---
DATA_STORAGE_PATH=./data
TRANSCRIPT_ARCHIVE_PATH=./data/transcripts
